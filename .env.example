# Moltbook API key — obtained after registering the agent
MOLTBOOK_API_KEY=

# MoltX Social API key — obtained via: npm run setup:moltx
MOLTX_API_KEY=

# Agent wallet private key (the oracle that resolves pools)
# Used by: agent scripts AND bot-moltx.js (EIP-712 wallet linking)
# The bot reads WALLET_PRIVATE_KEY first, falls back to AGENT_PRIVATE_KEY
AGENT_PRIVATE_KEY=
WALLET_PRIVATE_KEY=

# ── Base Mainnet RPC (FallbackProvider) ──
# The bot uses a FallbackProvider that cascades across multiple RPCs:
#   Priority 1: ALCHEMY_RPC_URL (weight 2, preferred)
#   Priority 2: INFURA_RPC_URL  (weight 1, backup)
#   Priority 3: BASE_RPC_URL    (weight 1, public fallback)
#
# IMPORTANT: The public RPC (mainnet.base.org) has aggressive rate limits
# and causes CALL_EXCEPTION errors under load. Set at least one paid provider.
ALCHEMY_RPC_URL=
INFURA_RPC_URL=
BASE_RPC_URL=https://mainnet.base.org

# USDC on Base Mainnet
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Protocol owner wallet (receives 3% fee)
PROTOCOL_OWNER=0x2b4D825417f568231e809E31B9332ED146760337

# Mogra Wallet API key — obtained from mogra.xyz
MOGRA_API_KEY=

# MutualLumina (standalone vault — no router needed)
LUMINA_CONTRACT_ADDRESS=
LUMINA_STAKING_ADDRESS=
LUMINA_FEE_ROUTER_ADDRESS=

# ── AutoResolver (Parametric Chainlink resolution) ──
# Deployed via: npm run deploy:autoresolver
# When set, the oracle bot will use on-chain Chainlink feeds for
# parametric pools (gas_spike, oracle_discrepancy, yield_drop)
# instead of the LLM dual-auth oracle.
AUTORESOLVER_ADDRESS=

# DisputeResolver (24h dispute window for Lumina pool resolutions)
DISPUTE_RESOLVER_ADDRESS=0x2e4D0112A65C2e2DCE73e7F85bF5C2889c7709cA

# ── Etherscan API Key (for gas oracle in oracle.js) ──
# Free tier: 5 req/s. Paid: 100+ req/s.
# Get one at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# ── WalletConnect Project ID (for React dApp / RainbowKit) ──
# Get one at: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# ── ACP (Virtuals Agent Commerce Protocol) ──
ACP_WALLET_PRIVATE_KEY=
ACP_ENTITY_ID=
ACP_AGENT_WALLET_ADDRESS=
ACP_RPC_URL=
