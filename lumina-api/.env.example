# ═══════════════════════════════════════════
# LUMINA API — Environment Variables
# ═══════════════════════════════════════════

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# Base L2 RPC (for on-chain verification)
# TODO: Required when blockchain integration is active
# BASE_RPC_URL=https://mainnet.base.org
# AGENT_PRIVATE_KEY=

# Contracts (Base Mainnet - already hardcoded in config, override here if needed)
# LUMINA_CONTRACT=0x1c5E5c90aC46e960aACbfCeAE9dEC2F79ce06bd7
# DISPUTE_RESOLVER=0x2e4D0112A65C2e2DCE73e7F85bF5C2889c7709cA
# USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Database (for production)
# TODO: Add when migrating from in-memory storage
# DATABASE_URL=postgresql://user:pass@localhost:5432/lumina

# Redis (for production caching)
# TODO: Add for quote caching and rate limit state
# REDIS_URL=redis://localhost:6379
